{
    "root": {
        "prototype": "mod/data/service/expression-data-mapping",
        "values": {
            "objectDescriptor": {"@": "EmploymentOfferDescriptor"},
            "rawDataPrimaryKeys":["id"],
            "objectMapping": {
                "rules": {
                    "acceptanceDate": {
                        "<->":"acceptanceDate",
                        "converter": {"@": "string-to-date-converter"}
                    },
                    "employmentPosition": {
                        "<->":"employmentPositionId",
                        "converter": {"@": "employmentPositionConverter"}
                    },
                    "hiringManager": {
                        "<->": "hiringManagerId",
                        "converter": {"@": "personConverter"}
                    },
                    "offerDate": {
                        "<->":"offerDate",
                        "converter": {"@": "string-to-date-converter"}
                    },
                    "receiptDate": {
                        "<->": "receiptDate",
                        "converter": {"@": "string-to-date-converter"}
                    },
                    "recipient": {
                        "<->":"recipientId",
                        "converter": {"@": "personConverter"}
                    },
                    "recruiter": {
                        "<->":"recruiterId",
                        "converter": {"@": "personConverter"}
                    },
                    "startDate": {
                        "<->": "startDate",
                        "converter": {"@": "string-to-date-converter"}
                    } 
                }
            },
            "rawDataMapping": {
                "rules": {
                }
            },
            "requisitePropertyNames": [
                "receiptDate", "startDate","employmentPosition","recipient","sender"
            ]
        }
    },

    "EmploymentOfferDescriptor": {
        "object": "business.mod/data/model/employment-offer.mjson"
    },

    "string-to-date-converter": {
        "prototype": "mod/core/converter/i-s-o-8601-formatted-string-to-date-converter"
    },

    "employmentPositionConverter": {
        "prototype": "mod/data/converter/raw-foreign-value-to-object-converter",
        "values": {
            "convertExpression": "id == $"
        }
    },
    "personConverter": {
        "prototype": "mod/data/converter/raw-foreign-value-to-object-converter",
        "values": {
            "convertExpression": "id == $"
        }
    }
}
